# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...


# ─── Resend (email) ──────────────────────────────────────────────────────────
# Free tier: 3,000 emails/month. Sign up at resend.com → see docs/setup-resend.md
RESEND_API_KEY=TODO_get_from_resend_com
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Generate with: openssl rand -hex 32
CRON_SECRET=TODO_generate_random_secret

# ─── OpenClaw ────────────────────────────────────────────────────────────────
# Leave SIMULATE=true during development — messages log to console instead of sending
OPENCLAW_BASE_URL=http://localhost:3001
OPENCLAW_API_KEY=TODO_your_openclaw_api_key
OPENCLAW_SIMULATE=true
